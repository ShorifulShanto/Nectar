
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "CentralHubEntry": {
      "title": "CentralHubEntry",
      "type": "object",
      "description": "A centralized log of all user activities, form submissions, and profile updates.",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["signup", "cart_addition", "newsletter", "profile_update", "account_deletion"] },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "payload": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Private user profiles."
    },
    "/central_hub/{entryId}": {
      "schema": { "$ref": "#/backend/entities/CentralHubEntry" },
      "description": "Centralized repository for all site data and activities."
    }
  }
}
