
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Simplified for the prototype to allow the current user to manage the site.
      // In a production environment, this would check for a specific role in a collection.
      return isSignedIn();
    }

    match /central_hub/{entryId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      match /cart/{cartId} {
        allow read, write: if isOwner(userId);
        match /items/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
